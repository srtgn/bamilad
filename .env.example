# Copy to .env and fill in real values. .env is gitignored; this example file is committed.

# ─── Database (PostgreSQL) ───────────────────────────────────────────────
# Local dev points at the docker-compose Postgres on host port 5433 (5432 is often
# already taken by a native Postgres). On Railway this is injected automatically.
DATABASE_URL="postgresql://bamilad:bamilad@127.0.0.1:5433/bamilad?schema=public"

# ─── Auth.js v5 ──────────────────────────────────────────────────────────
# Generate a secret with:  openssl rand -base64 32
AUTH_SECRET="replace-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Optional Google OAuth (leave blank to keep it disabled)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# ─── Stripe ──────────────────────────────────────────────────────────────
# Test keys from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY="sk_test_xxx"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_xxx"
# From `stripe listen` locally, or the webhook endpoint settings in production
STRIPE_WEBHOOK_SECRET="whsec_xxx"

# ─── Email (Resend) ──────────────────────────────────────────────────────
RESEND_API_KEY="re_xxx"
# Use onboarding@resend.dev for testing; a verified domain for production
EMAIL_FROM="SERENIQ <onboarding@resend.dev>"

# ─── Image uploads (Cloudinary) ──────────────────────────────────────────
CLOUDINARY_URL="cloudinary://API_KEY:API_SECRET@CLOUD_NAME"
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_UPLOAD_PRESET="sereniq_unsigned"

# ─── Seed admin user (used by prisma/seed.ts) ────────────────────────────
ADMIN_EMAIL="admin@sereniq.test"
ADMIN_PASSWORD="ChangeMe123!"
